{
  "name": "@synpress/metamask-extension-no-lavamoat-builder",
  "version": "0.0.0-private",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.14.1"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "check:upstream": "tsx src/cli/check-for-upstream-release.ts",
    "build:release": "tsx src/cli/build-release.ts"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@biomejs/biome": "2.4.10",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
